# Copy to .env and fill in. Never commit the real .env.

# --- API (apps/api) ---
NODE_ENV=development
PORT=3000

# Postgres + Redis (host ports match docker-compose.yml; chosen to avoid clashes)
DATABASE_URL=postgres://mihrab:mihrab@localhost:5433/mihrab
REDIS_URL=redis://localhost:6379

# Better Auth (generate a strong secret: `openssl rand -base64 32`)
BETTER_AUTH_SECRET=replace-with-a-32+-char-random-secret
BETTER_AUTH_URL=http://localhost:3000

# Comma-separated allowlist of browser origins (CORS + CSRF trusted origins)
CORS_ORIGINS=http://localhost:5173

# --- Web (apps/web, Vite — only VITE_* vars reach the browser) ---
# Leave empty in dev: the Vite proxy serves /api same-origin so cookies "just work".
VITE_API_URL=
